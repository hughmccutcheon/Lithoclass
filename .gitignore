# local working docs (personal planning notes, not part of the public repo)
PROJECT_BRIEF.md
KICKOFF_PROMPT.md
HUGH_BRIEFING.md
INTERPRETATION_QUESTIONS.md

# raw data is never committed
data/raw/*
!data/raw/.gitkeep

# processed data regenerates from raw; the small modelling table is
# committed so figures/results reproduce without the 22 GB raw download
# (derivative of CC-BY 4.0 SARIG data — see README attribution)
data/processed/*
!data/processed/.gitkeep
!data/processed/clean.parquet

# environment
.venv/

# python
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# tooling caches
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
